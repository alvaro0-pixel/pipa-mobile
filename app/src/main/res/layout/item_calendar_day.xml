<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout de cada célula de dia do CalendarView (Kizitonwose).
    Referenciado por app:cv_dayViewResource no fragment_classroom_detail.xml.
    Deve ficar em: res/layout/item_calendar_day.xml
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="40dp"
    android:orientation="vertical"
    android:gravity="center">

    <TextView
        android:id="@+id/tv_day_text"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:gravity="center"
        android:textSize="13sp"
        android:textColor="@color/white" />

    <View
        android:id="@+id/view_dot"
        android:layout_width="6dp"
        android:layout_height="6dp"
        android:background="@drawable/bg_dot_default"
        android:visibility="invisible" />

</LinearLayout>